# PostgreSQL to answer questions about. USE A READ-ONLY ROLE — it is the hard
# security boundary for model-generated SQL.
#   CREATE ROLE ai_chat_ro LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE mydb TO ai_chat_ro;
#   GRANT USAGE ON SCHEMA public TO ai_chat_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO ai_chat_ro;
DATABASE_URL=postgres://ai_chat_ro:password@host.docker.internal:5432/mydb

# Your Anthropic API key. The only network egress of this service.
ANTHROPIC_API_KEY=sk-ant-...

# Primary bearer token for the UI and API. Generate one:
#   openssl rand -hex 32
APP_ACCESS_TOKEN=

# Optional overrides
# PORT=8080
# AI_CHAT_MODEL=claude-opus-4-8
# AI_CHAT_DB_PATH=/data/ai-chat.sqlite
